{
  "manifest_version": 3,
  "name": "ChatGPT Prompt Manager – Save & Reuse Prompts",
  "version": "1.0.0",
  "description": "Save, search, and insert reusable prompts directly inside ChatGPT.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "utils/dom.js",
        "storage/storage.js",
        "content/content.js",
        "content/sidebar.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/sidebar.html",
        "content/sidebar.css"
      ],
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ]
    }
  ]
}